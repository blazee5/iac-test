kubeconfig_path = "~/.kube/config"
kube_context    = ""

namespace            = "project"
monitoring_namespace = "monitoring"

app_image_repository = "ghcr.io/blazee5/iac-test"
app_image_tag        = "latest"

grafana_admin_password = "password"

hpa_min_replicas = 2
hpa_max_replicas = 8

app_ingress_enabled    = true
app_ingress_class_name = "traefik"
app_ingress_host       = ""
app_ingress_path       = "/"

grafana_ingress_enabled    = true
grafana_ingress_class_name = "traefik"
grafana_ingress_host       = ""
grafana_ingress_path       = "/grafana"
